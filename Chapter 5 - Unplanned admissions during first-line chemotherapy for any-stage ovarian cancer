Create cycle numbers, retain only first-line therapy, and define dose relative to baseline dose.
```{r}
cycles<-cohort %>% 
  mutate(ACTUAL_DOSE_PER_ADMINISTRATION=as.numeric(ACTUAL_DOSE_PER_ADMINISTRATION)) %>% 
  filter(str_detect(DRUG_GROUP,"CARBO|PACLI")) %>% 
  mutate(ADMINISTRATION_DATE=as.Date(ADMINISTRATION_DATE)) %>% 
  arrange(PSEUDO_PAT, ADMINISTRATION_DATE) %>% 
  group_by(PSEUDO_PAT) %>% 
  distinct(PSEUDO_PAT, ADMINISTRATION_DATE,.keep_all=T) %>% 
  mutate(daysbetweentreatment=difftime(ADMINISTRATION_DATE, lag(ADMINISTRATION_DATE),units="days")) %>% 
  mutate(cycle_number=row_number()) %>% 
  select(PSEUDO_PAT, DRUG_GROUP, ADMINISTRATION_DATE,  cycle_number,daysbetweentreatment, ACTUAL_DOSE_PER_ADMINISTRATION) %>% 
  ungroup() %>% 
  mutate(baseline_dose=ifelse(cycle_number==1, ACTUAL_DOSE_PER_ADMINISTRATION,NA)) %>% 
  group_by(PSEUDO_PAT, DRUG_GROUP) %>% 
  fill(baseline_dose,.direction="down") %>% 
  group_by(PSEUDO_PAT) %>%
  mutate(cyclefilter=max(cycle_number)) %>% 
  filter(cycle_number>1|cyclefilter==1) %>% 
  mutate(filter=ifelse(daysbetweentreatment>181,1,NA)) %>% 
  fill(filter,.direction="down") %>% 
  filter(is.na(filter)) %>% 
  mutate(regimen=ifelse(mean(daysbetweentreatment)<14,"Weekly","Three-weekly"))

cycles2<-cycles %>% 
  group_by(PSEUDO_PAT) %>% 
  mutate(relative_dose=ACTUAL_DOSE_PER_ADMINISTRATION/baseline_dose) %>% 
  group_by(PSEUDO_PAT, DRUG_GROUP) %>% 
  #filter(!is.na(relative_dose)) %>% 
  mutate(relative_dose_mean=mean(relative_dose))

cycles2 %>% 
  write_csv("relative_dose.csv")
