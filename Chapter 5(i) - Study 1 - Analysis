Analysis: primary surgery cohort:
Split analyses by surgery type. We are only looking at advanced stage disease now (N=12,508)
```{r}
#Table one for primary surgery cohort
advanced_stage %>% 
  filter(surgery=="PDS") %>% 
  select(admission_within_30_days,admission_within_126_days,indextoadmission, emergency_diagnosis_flag,surgery,twomonth_mortality,oneyear_mortality, fiveyear_mortality,notreatmentafteradmission,diedduringadmission, AGE,AGE2,GRADE,STAGE_BEST,STAGE_BEST_CLEAN,BMI,BMI2, PS,PS2,IMD2015_1,ethnicitygroup,ETHNICITY2,REGION,CENTRETYPE,regimen,year_of_treatment) %>% 
  mutate(ifelse(emergency_diagnosis_flag==1,"Emergency diagnosis 28 days", "No emergency diagnosis")) %>% 
  tbl_summary(by="emergency_diagnosis_flag")%>% 
  add_n() %>% 
  add_overall() %>% 
  add_p() %>% 
  add_ci() %>% 
  as_gt() %>% 
  gt::gtsave("summary_table_PDS.docx")

#Glm for association of emergency diagnosis with hospitalisation during first-line chemotherapy

#Primary surgery
PDS<-regression_data2 %>% 
  mutate(admission_within_30_days=as.numeric(admission_within_30_days)) %>% 
  mutate(admission_within_126_days=as.numeric(admission_within_126_days)) %>% 
  filter(surgery=="PDS")

#Glm for advanced patients only
PDSglm<-glm(admission_within_126_days~emergency_diagnosis_flag+ IMD2015_1+REGION+CENTRETYPE+ETHNICITYNAME+AGE2+STAGE_BEST+GRADE+PS2+BMI2+regimen,data=PDS,family="binomial")

#Summarise logistic regression
summary(PDSglm) #n=2215

#Create summary table of odds ratios using exponentiated coefficients from glm above.
advanced_stage_surgery_table<-tbl_regression(PDSglm, exponentiate = TRUE)

#Save output of logistic regression analysis
advanced_stage_surgery_table %>% 
  as_gt() %>% 
  gt::gtsave("glm_pds_advanced_stage.docx")

