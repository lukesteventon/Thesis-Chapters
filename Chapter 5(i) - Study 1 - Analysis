```{r cars}
regression_data2<-read_csv(
  "K:\\QNAP\\BRCT\\SACT project\\LSanalysis\\Thesis Chapters\\Chapter 5 - Unplanned admissions during first-line chemotherapy\\regression_data.csv",
  col_names = TRUE,
  col_types = cols(.default = col_character()),
  col_select = NULL) %>% 
  mutate(indextoadmission=as.numeric(indextoadmission)) %>% 
  mutate(emergency_diagnosis_flag=ifelse(is.na(emergency_diagnosis_flag),0,emergency_diagnosis_flag)) %>% 
  mutate(admission_within_30_days=ifelse(is.na(admission_within_30_days),0,admission_within_30_days)) %>%
  mutate(admission_within_126_days=ifelse(is.na(admission_within_126_days),0,admission_within_126_days)) %>%
  group_by(PSEUDO_PAT) %>% 
  mutate(index=as.Date(index)) %>% 
  mutate(VITALSTATUSDATE=dmy(VITALSTATUSDATE)) %>%
  mutate(survival=difftime(VITALSTATUSDATE,index, units = "days")) %>% 
  mutate(twomonth_mortality=ifelse(survival<62&!is.na(survival)&str_detect(VITALSTATUS,"D"),1,0)) %>% 
  mutate(oneyear_mortality=ifelse(survival<366&!is.na(survival)&str_detect(VITALSTATUS,"D"),1,0)) %>% 
  mutate(fiveyear_mortality=ifelse(survival<1825&!is.na(survival)&str_detect(VITALSTATUS,"D"),1,0)) %>% 
  ungroup()
```

